{
  "name": "web-marker-extension",
  "version": "0.2.0",
  "private": true,
  "description": "Web Marker - 网页高亮标注 Chrome 扩展",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "wxt": "^0.20.0"
  }
}
